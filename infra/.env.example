# Infrastructure secrets — source this file or use direnv
# Copy to .env and fill in values: cp .env.example .env

# Provider tokens
export TF_VAR_hetzner_token=""           # Hetzner Cloud API token
export TF_VAR_cloudflare_api_token=""    # Cloudflare API token (R2 + DNS permissions)
export TF_VAR_vercel_api_token=""        # Vercel API token (Full Access scope)
export TF_VAR_github_token=""            # GitHub PAT (repo + admin:org scope)

# Hetzner VPS
export TF_VAR_ssh_public_key=""          # Contents of ~/.ssh/id_ed25519.pub

# Cloudflare
export TF_VAR_cloudflare_account_id=""   # Cloudflare account ID
export TF_VAR_cloudflare_zone_id=""      # Cloudflare DNS zone ID

# Vercel
export TF_VAR_vercel_org_id=""           # Vercel organization/team ID

# Secrets passed through to GitHub Actions
export TF_VAR_r2_access_key_id=""        # R2 S3-compatible access key ID
export TF_VAR_r2_secret_access_key=""    # R2 S3-compatible secret access key
export TF_VAR_motherduck_token=""        # MotherDuck API token

# S3 backend credentials (for tofu init — R2 state bucket)
export AWS_ACCESS_KEY_ID=""              # R2 API token access key
export AWS_SECRET_ACCESS_KEY=""          # R2 API token secret key

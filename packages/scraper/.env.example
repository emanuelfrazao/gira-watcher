# Storage backend (required)
GIRA_STORAGE_URL=duckdb:///path/to/gira_local.duckdb
# GIRA_STORAGE_TOKEN=md_<your-motherduck-token>  # Required for MotherDuck

# GIRA API credentials (required for all runs — all endpoints require JWT auth)
GIRA_API_EMAIL=your-gira-account@example.com
GIRA_API_PASSWORD=your-gira-password

# API endpoint configuration (optional — defaults to GIRA production)
# GIRA_API_BASE_URL=https://c2g091p01.emel.pt/ws/graphql
# GIRA_API_AUTH_URL=https://c2g091p01.emel.pt/auth/login

# Logging
# APP_ENV=development  # Set to "production" for JSON output
# LOG_LEVEL=INFO       # DEBUG, INFO, WARNING, ERROR

# Scraper identity
GIRA_SCHEDULER_IDENTITY=local-dev
# GIRA_COMMIT_SHA=auto  # Defaults to "unknown" if not set

# Audit (optional)
# GITHUB_AUDIT_TOKEN=ghp_<token>
# GITHUB_AUDIT_REPO=<user>/gira-watcher-audit

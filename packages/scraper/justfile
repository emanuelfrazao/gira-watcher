# Run all quality checks
check: lint typecheck test

# Lint with ruff
lint:
    uv run ruff check .
    uv run ruff format --check .

# Auto-fix lint and format
format:
    uv run ruff check --fix .
    uv run ruff format .

# Type-check with pyright
typecheck:
    uv run pyright

# Run all tests
test:
    uv run pytest

# Run unit tests only
test-unit:
    uv run pytest -m unit

# Run integration tests only
test-integration:
    uv run pytest -m integration

# Run scraper locally
run *ARGS:
    uv run python -m scraper.main {{ARGS}}

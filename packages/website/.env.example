# Server-only — MotherDuck connection via Postgres wire protocol
MOTHERDUCK_TOKEN=your_motherduck_api_token
MOTHERDUCK_HOST=pg.us-east-1-aws.motherduck.com
MOTHERDUCK_DATABASE=gira

# Public — exposed to client via $env/static/public
PUBLIC_TILE_URL=https://tiles.openfreemap.org/styles/positron/style.json
PUBLIC_GITHUB_REPO=mano/gira-watcher
PUBLIC_MOTHERDUCK_SHARE=md:_share/gira/public

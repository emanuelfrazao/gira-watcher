# GIRA Watch — Environment Variables
# Copy to .env and fill in values. See per-package .env.example for details.

# === Scraper ===
# GIRA API credentials (for authenticated endpoints: dock/bike detail)
GIRA_API_EMAIL=your-gira-account@example.com
GIRA_API_PASSWORD=your-gira-password

# Storage backend
GIRA_STORAGE_URL=duckdb:///gira_local.duckdb
# GIRA_STORAGE_TOKEN=md_<your-motherduck-token>  # Required for MotherDuck

# Scraper identity
GIRA_SCHEDULER_IDENTITY=local-dev
# GIRA_COMMIT_SHA=auto  # VPS only — resolved via git rev-parse HEAD

# Audit publishing (VPS only)
# GITHUB_AUDIT_TOKEN=ghp_<github-personal-access-token>
# GITHUB_AUDIT_REPO=<user>/gira-watcher-audit

# === Website (see packages/website/.env.example) ===
# MOTHERDUCK_TOKEN=md_<token>
# MOTHERDUCK_HOST=md-<id>.motherduck.com
# MOTHERDUCK_DATABASE=gira

# === Infrastructure (see infra/.env.example) ===
# TF_VAR_hcloud_token=<hetzner-api-token>
# TF_VAR_cloudflare_api_token=<cloudflare-api-token>
# TF_VAR_vercel_api_token=<vercel-api-token>
